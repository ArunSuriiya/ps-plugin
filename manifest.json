{
  "manifestVersion": 5,
  "id": "com.antigravity.asset-library",
  "name": "Asset Library",
  "version": "1.0.0",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "23.0.0"
    },
    {
      "app": "ILST",
      "minVersion": "27.0.0"
    }
  ],
  "entryPoints": [
    {
      "type": "panel",
      "id": "assetLibraryPanel",
      "label": {
        "default": "Asset Library"
      },
      "minimumSize": {
        "width": 300,
        "height": 600
      },
      "preferredSize": {
        "width": 350,
        "height": 900
      }
    }
  ],
  "permissions": {
    "localFileSystem": "plugin",
    "launchProcess": "none"
  }
}